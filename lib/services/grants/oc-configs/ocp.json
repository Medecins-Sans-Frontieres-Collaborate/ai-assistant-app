{
  "name": "OCP",
  "code_regex": "^[A-Z]{2}\\d{2,4}[A-Z]?$",
  "code_prefix": "",
  "hq_rate": 0.15,
  "direct_rate": 0.85,
  "multi_project": true,
  "coord_keywords": ["coordination", "coodination", "mission", "strategy"],
  "exclude_keywords": [],
  "supplemental_files": {
    "allocation_list": {
      "filename": "OCP-Allocation-List.csv",
      "skiprows": 0,
      "columns": {
        "code": "Project Code",
        "name": "Project Name in OCP's Allocation Spreadsheet",
        "country": "Country"
      }
    },
    "emergency_budgets": {
      "filename": "OCP-Emergency-Classifications.csv",
      "skiprows": 1,
      "columns": {
        "code": "Project code",
        "emergency": "Emergency?"
      }
    },
    "budgets": {
      "filename": "OCP-Initial-Budgets.csv",
      "skiprows": 1,
      "columns": {
        "code": "Project code",
        "amount": "Amount in EUR"
      }
    },
    "sanctions": {
      "filename": "OCP-Sanctions.csv",
      "skiprows": 0,
      "columns": {
        "code": "HQ/OC Project",
        "sanctions": "Sanctions"
      }
    }
  }
}
